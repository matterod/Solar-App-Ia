# ===========================================
# Solar ERP — Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.

# Database
DATABASE_URL=postgresql+asyncpg://solar_admin:solar_secret_2024@database:5432/solar_erp

# Security
SECRET_KEY=super-secret-key-change-in-production

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# S3-compatible Storage (Cloudflare R2 / MinIO / AWS S3)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=solar-erp-photos

# AI Agent (Anthropic Claude)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# WhatsApp API (future integration)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
